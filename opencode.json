{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/guides/*.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "api-reviewer": {
      "description": "Reviews Laravel API code for conventions and best practices.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
